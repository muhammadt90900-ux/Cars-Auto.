// apps/api/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS — platform
// ─────────────────────────────────────────────

enum UserRole {
  USER
  DEALER
  ADMIN
}

enum ListingType {
  CAR
  MOTORCYCLE
  SPARE_PART
}

enum ListingCondition {
  NEW
  USED
  SALVAGE
}

enum ListingStatus {
  ACTIVE
  SOLD
  DRAFT
  EXPIRED
  PENDING
  REJECTED
}

// ─────────────────────────────────────────────
// ENUMS — automotive (replaces raw strings)
// ─────────────────────────────────────────────

enum FuelType {
  PETROL
  DIESEL
  HYBRID
  PLUG_IN_HYBRID
  ELECTRIC
  LPG
  CNG
  HYDROGEN
}

enum TransmissionType {
  MANUAL
  AUTOMATIC
  SEMI_AUTOMATIC
  CVT
  DUAL_CLUTCH
}

enum DrivetrainType {
  FWD   // Front-wheel drive
  RWD   // Rear-wheel drive
  AWD   // All-wheel drive
  FOUR_WD // Part-time 4WD
}

enum BodyType {
  SEDAN
  HATCHBACK
  SUV
  CROSSOVER
  COUPE
  CONVERTIBLE
  WAGON
  PICKUP_TRUCK
  VAN
  MINIVAN
  BUS
  OTHER
}

// ─────────────────────────────────────────────
// AUTOMOTIVE REFERENCE TABLES
// ─────────────────────────────────────────────

/// Top-level brand (Toyota, BMW, Kia …)
model CarBrand {
  id          String      @id @default(uuid())
  slug        String      @unique          // "toyota", "bmw" — URL-safe identifier
  nameEn      String
  nameAr      String
  nameKu      String
  nameZh      String
  logoUrl     String?
  countryCode String                       // ISO 3166-1 alpha-2, e.g. "JP", "DE"
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  models      CarModel[]

  @@index([slug])
  @@index([countryCode])
}

/// A model line under a brand (Camry, X5, Sportage …)
model CarModel {
  id          String      @id @default(uuid())
  brandId     String
  brand       CarBrand    @relation(fields: [brandId], references: [id])
  slug        String                       // "camry", "x5" — unique per brand
  nameEn      String
  nameAr      String
  nameKu      String
  nameZh      String
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  generations CarModelGeneration[]

  @@unique([brandId, slug])
  @@index([brandId])
}

/// A generation / facelift of a model (e.g. Camry XV70 2018-2023)
/// Enables accurate production-year filtering without storing years[] arrays.
model CarModelGeneration {
  id           String      @id @default(uuid())
  modelId      String
  model        CarModel    @relation(fields: [modelId], references: [id])
  name         String?                     // Optional label, e.g. "XV70", "F30", "4th Gen"
  yearFrom     Int                         // First production year (inclusive)
  yearTo       Int?                        // Last production year; NULL = still in production
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  trims        CarTrim[]

  @@index([modelId])
  @@index([yearFrom, yearTo])
}

/// A specific trim / variant within a generation
/// (e.g. Camry LE, XLE, XSE — each may differ in drivetrain, engine, etc.)
model CarTrim {
  id             String             @id @default(uuid())
  generationId   String
  generation     CarModelGeneration @relation(fields: [generationId], references: [id])
  name           String                         // "LE", "XLE", "AMG Line" …
  bodyType       BodyType
  fuelType       FuelType
  transmission   TransmissionType
  drivetrain     DrivetrainType
  engineCC       Int?                           // Displacement in cc, e.g. 2494
  engineLabel    String?                        // Human label, e.g. "2.5L 4-cyl"
  powerKw        Int?                           // Engine power in kW
  doors          Int?
  seats          Int?
  isActive       Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  listingSpecs   ListingVehicleSpec[]

  @@index([generationId])
  @@index([bodyType])
  @@index([fuelType])
  @@index([drivetrain])
}

// ─────────────────────────────────────────────
// LISTING VEHICLE SPECIFICATION
// Separates vehicle data from listing metadata.
// A listing owns exactly one spec row (1-to-1).
// ─────────────────────────────────────────────

/// Structured vehicle data attached to a Listing.
/// All automotive fields live here — keeps Listing lean.
model ListingVehicleSpec {
  id             String             @id @default(uuid())
  listingId      String             @unique
  listing        Listing            @relation(fields: [listingId], references: [id], onDelete: Cascade)

  // ── Structured references (preferred path) ──────────────────
  trimId         String?
  trim           CarTrim?           @relation(fields: [trimId], references: [id])

  // ── Denormalized overrides / legacy / free-text vehicles ────
  // Populated when a seller chooses a brand/model without a matching
  // trim in the catalogue, or when importing external data.
  brandId        String?
  brand          CarBrand?          @relation(fields: [brandId], references: [id])
  modelId        String?
  model          CarModel?          @relation(fields: [modelId], references: [id])
  year           Int?               // Actual production year of this vehicle
  bodyType       BodyType?
  fuelType       FuelType?
  transmission   TransmissionType?
  drivetrain     DrivetrainType?
  engineCC       Int?
  engineLabel    String?
  powerKw        Int?
  doors          Int?
  seats          Int?

  // ── Condition / usage ────────────────────────────────────────
  condition      ListingCondition?
  mileageKm      Int?
  color          String?            // Free text or a future Color enum
  vin            String?            // Vehicle Identification Number

  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([brandId])
  @@index([modelId])
  @@index([trimId])
  @@index([year])
  @@index([fuelType])
  @@index([bodyType])
  @@index([drivetrain])
}

// ─────────────────────────────────────────────
// SPARE PARTS COMPATIBILITY
// Replaces incompatible String[] arrays with
// proper relational rows.
// ─────────────────────────────────────────────

/// Compatibility entry linking a spare-part listing to
/// specific brands, models, and year ranges.
model PartCompatibility {
  id          String      @id @default(uuid())
  listingId   String
  listing     Listing     @relation(fields: [listingId], references: [id], onDelete: Cascade)

  brandId     String?
  brand       CarBrand?   @relation(fields: [brandId], references: [id])
  modelId     String?
  model       CarModel?   @relation(fields: [modelId], references: [id])
  yearFrom    Int?
  yearTo      Int?
  notes       String?     // e.g. "only 4-cyl variants"

  @@index([listingId])
  @@index([brandId])
  @@index([modelId])
}

// ─────────────────────────────────────────────
// LISTING (trimmed — automotive detail offloaded)
// ─────────────────────────────────────────────

model Listing {
  id            String            @id @default(uuid())
  type          ListingType
  status        ListingStatus     @default(ACTIVE)
  userId        String
  user          User              @relation(fields: [userId], references: [id])

  titleKu       String
  titleAr       String
  titleEn       String
  titleZh       String
  descriptionKu String?
  descriptionAr String?
  descriptionEn String?
  descriptionZh String?

  price         Float
  currency      String            @default("USD")
  negotiable    Boolean           @default(false)

  locationId    String?
  location      Location?         @relation(fields: [locationId], references: [id])

  categoryId    String?
  category      Category?         @relation(fields: [categoryId], references: [id])

  partNumber    String?           // Spare parts only

  views         Int               @default(0)
  featured      Boolean           @default(false)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  // relations
  vehicleSpec        ListingVehicleSpec?
  partCompatibility  PartCompatibility[]
  images             Image[]
  chats              Chat[]

  @@index([status])
  @@index([type, status])
  @@index([userId])
}

// ─────────────────────────────────────────────
// UNCHANGED SUPPORTING MODELS
// ─────────────────────────────────────────────

model Image {
  id        String  @id @default(uuid())
  url       String
  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  isCover   Boolean @default(false)
  order     Int     @default(0)
}

model Category {
  id       String     @id @default(uuid())
  parentId String?
  parent   Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children Category[] @relation("SubCategories")
  nameKu   String
  nameAr   String
  nameEn   String
  nameZh   String
  icon     String?
  slug     String     @unique
  listings Listing[]
}

model Location {
  id          String    @id @default(uuid())
  country     String
  governorate String?
  city        String
  nameKu      String
  nameAr      String
  nameEn      String
  nameZh      String
  lat         Float
  lng         Float
  listings    Listing[]
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  phone     String?
  password  String?
  name      String
  avatar    String?
  role      UserRole @default(USER)
  verified  Boolean  @default(false)
  locale    String   @default("ku")
  googleId  String?
  appleId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listings        Listing[]
  chatsAsBuyer    Chat[]         @relation("BuyerChats")
  chatsAsSeller   Chat[]         @relation("SellerChats")
  messages        Message[]
  notifications   Notification[]
  reviewsGiven    Review[]       @relation("Reviewer")
  reviewsReceived Review[]       @relation("Reviewee")
  payments        Payment[]
  reports         Report[]
}

model Chat {
  id        String    @id @default(uuid())
  listingId String
  listing   Listing   @relation(fields: [listingId], references: [id])
  buyerId   String
  buyer     User      @relation("BuyerChats", fields: [buyerId], references: [id])
  sellerId  String
  seller    User      @relation("SellerChats", fields: [sellerId], references: [id])
  status    String    @default("active")
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Message {
  id        String    @id @default(uuid())
  chatId    String
  chat      Chat      @relation(fields: [chatId], references: [id])
  senderId  String
  sender    User      @relation(fields: [senderId], references: [id])
  content   String
  type      String    @default("text")
  mediaUrl  String?
  readAt    DateTime?
  createdAt DateTime  @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  title     String
  body      String
  data      Json?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Review {
  id         String   @id @default(uuid())
  reviewerId String
  reviewer   User     @relation("Reviewer", fields: [reviewerId], references: [id])
  revieweeId String
  reviewee   User     @relation("Reviewee", fields: [revieweeId], references: [id])
  rating     Int
  comment    String
  createdAt  DateTime @default(now())
}

model Payment {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  plan      String
  amount    Float
  currency  String
  status    String
  createdAt DateTime @default(now())
}

model Report {
  id         String   @id @default(uuid())
  reporterId String
  reporter   User     @relation(fields: [reporterId], references: [id])
  targetType String
  targetId   String
  reason     String
  status     String   @default("pending")
  createdAt  DateTime @default(now())
}
